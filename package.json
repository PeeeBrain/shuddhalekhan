{
  "name": "shuddhalekhan",
  "private": true,
  "version": "0.0.0-development",
  "description": "Shuddhalekhan — speech-to-text dictation app",
  "type": "module",
  "main": "./out/main/index.cjs",
  "author": "parthashirolkar",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && bun run build:agent",
    "build:agent": "vite build --config vite.agent.config.ts",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "verify:whisper": "bun scripts/verify-whisper-endpoint.ts",
    "test:transcription-quality": "bun scripts/transcription-quality.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/mcp": "2.0.10",
    "@ai-sdk/openai-compatible": "3.0.7",
    "@tailwindcss/vite": "^4.3.2",
    "ai": "7.0.22",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.0",
    "koffi": "^2.9.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.6",
    "electron-vite": "^5.0.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "happy-dom": "^20.10.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "com.shuddhalekhan.app",
    "productName": "Shuddhalekhan",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "PeeeBrain",
      "repo": "shuddhalekhan",
      "releaseType": "draft",
      "publishAutoUpdate": true
    }
  }
}
